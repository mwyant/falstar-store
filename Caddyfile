:{$PORT:8080} {
    log {
        output stdout
    }

    encode gzip zstd

    route {
        # Static Asset Caching
        @static {
            path *.jpg *.jpeg *.png *.svg *.webp *.avif *.ico *.woff *.woff2 *.pdf
        }
        header @static Cache-Control "public, max-age=31536000, immutable"

        # SvelteKit App
        handle {
            root * /srv/falstar-store
            
            header {
                X-Frame-Options "SAMEORIGIN"
                X-Content-Type-Options "nosniff"
                Referrer-Policy "strict-origin-when-cross-origin"
                Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
                # CSP for Lemon Squeezy and BookFunnel
                Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://app.lemonsqueezy.com https://*.bookfunnel.com; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https://*.lemonsqueezy.com; connect-src 'self' https://app.lemonsqueezy.com; frame-src https://app.lemonsqueezy.com; object-src 'none';"
            }
            
            try_files {path} {path}.html /404.html
            file_server
        }
    }
}
